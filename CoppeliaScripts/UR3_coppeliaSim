    sim = require'sim'                                                                                                                                                                                                                                                          
    simROS2 = require'simROS2'                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                
    function jointTrajectoryCallback(msg)                                                                                                                                                                                                                                       
        if msg.points and #msg.points > 0 then                                                                                                                                                                                                                                  
            currentTrajectory = {}                                                                                                                                                                                                                                              
            trajectoryStartTime = sim.getSimulationTime()                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                                                
            local offsets = {                                                                                                                                                                                                                                                   
                shoulder_pan_joint = 0.0,                                                                                                                                                                                                                                       
                shoulder_lift_joint = math.pi / 2,                                                                                                                                                                                                                              
                elbow_joint = 0.0,                                                                                                                                                                                                                                              
                wrist_1_joint = math.pi / 2,                                                                                                                                                                                                                                    
                wrist_2_joint = 0.0,                                                                                                                                                                                                                                            
                wrist_3_joint = 0.0,                                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                                                
            local joint_map = {                                                                                                                                                                                                                                                 
                shoulder_pan_joint = 1,                                                                                                                                                                                                                                         
                shoulder_lift_joint = 2,                                                                                                                                                                                                                                        
                elbow_joint = 3,                                                                                                                                                                                                                                                
                wrist_1_joint = 4,                                                                                                                                                                                                                                              
                wrist_2_joint = 5,                                                                                                                                                                                                                                              
                wrist_3_joint = 6                                                                                                                                                                                                                                               
            }                                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                                                
            local mapped_indices = {}                                                                                                                                                                                                                                           
            for i, joint_name in ipairs(msg.joint_names) do                                                                                                                                                                                                                     
                local coppelia_idx = joint_map[joint_name]                                                                                                                                                                                                                      
                if coppelia_idx then                                                                                                                                                                                                                                            
                    mapped_indices[i] = {idx = coppelia_idx, offset = offsets[joint_name]}                                                                                                                                                                                      
                end                                                                                                                                                                                                                                                             
            end                                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                                                
            if #msg.points == 1 then                                                                                                                                                                                                                                            
                local startConfCoppelia = {}                                                                                                                                                                                                                                    
                for i = 1, 6 do                                                                                                                                                                                                                                                 
                    startConfCoppelia[i] = sim.getJointPosition(jointHandles[i])                                                                                                                                                                                                
                end                                                                                                                                                                                                                                                             
                table.insert(currentTrajectory, {time = 0.0, pos = startConfCoppelia})                                                                                                                                                                                          
            end                                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                                                
            for i, point in ipairs(msg.points) do                                                                                                                                                                                                                               
                local t = point.time_from_start.sec + (point.time_from_start.nanosec * 1e-9)                                                                                                                                                                                    
                local targetConfCoppelia = {}                                                                                                                                                                                                                                   
                for msg_idx, mapping in pairs(mapped_indices) do                                                                                                                                                                                                                
                    targetConfCoppelia[mapping.idx] = point.positions[msg_idx] + mapping.offset                                                                                                                                                                                 
                end                                                                                                                                                                                                                                                             
                table.insert(currentTrajectory, {time = t, pos = targetConfCoppelia})                                                                                                                                                                                           
            end                                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                                                
            sim.addLog(sim.verbosity_infos, string.format("Recebida trajetória com %d pontos. Duração: %.2f s", #msg.points, currentTrajectory[#currentTrajectory].time))                                                                                                       
        end                                                                                                                                                                                                                                                                     
    end                                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                                                
    function sysCall_init()                                                                                                                                                                                                                                                     
        sim.addLog(sim.verbosity_infos, "Inicializando subscriber ROS2 e Gêmeo Digital TURBINADO...")                                                                                                                                                                           
        simROS2 = require'simROS2'                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                
        jointHandles = {}                                                                                                                                                                                                                                                       
        for i=1,6,1 do                                                                                                                                                                                                                                                          
            jointHandles[i] = sim.getObject('../joint', {index=i-1})                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                
            -- ======= NOVO: BLINDAGEM DE PID E TORQUE =======                                                                                                                                                                                                                  
            -- Vamos injetar 5.000 N.m de força máxima e aumentar o ganho Proporcional (P) do motor                                                                                                                                                                             
            -- para garantir que a inércia não arraste o braço para fora da curva matemática                                                                                                                                                                                    
            sim.setJointForce(jointHandles[i], 5000.0)                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                
            -- Usando pcall para evitar erro caso a versão do CoppeliaSim mude o nome do parâmetro                                                                                                                                                                              
            pcall(function()                                                                                                                                                                                                                                                    
                sim.setObjectFloatParam(jointHandles[i], sim.jointfloatparam_pid_p, 100.0)                                                                                                                                                                                      
            end)                                                                                                                                                                                                                                                                
            -- ===============================================                                                                                                                                                                                                                  
        end                                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                                                
        currentTrajectory = nil                                                                                                                                                                                                                                                 
        trajectoryStartTime = 0                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                                                
        subscriber = simROS2.createSubscription(                                                                                                                                                                                                                                
            '/scaled_joint_trajectory_controller/joint_trajectory',                                                                                                                                                                                                             
            'trajectory_msgs/msg/JointTrajectory',                                                                                                                                                                                                                              
            'jointTrajectoryCallback'                                                                                                                                                                                                                                           
        )                                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                                                
        local filename = "/home/anderson/ur3_ws/csv_logs/coppelia_log_" .. tostring(math.floor(sim.getSystemTime())) .. ".csv"                                                                                                                                                  
        csv_file = io.open(filename, "w")                                                                                                                                                                                                                                       
        if csv_file then                                                                                                                                                                                                                                                        
            csv_file:write("timestamp,source,shoulder_pan,shoulder_lift,elbow,wrist_1,wrist_2,wrist_3\n")                                                                                                                                                                       
        end                                                                                                                                                                                                                                                                     
    end                                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                                                
    function sysCall_actuation()                                                                                                                                                                                                                                                
        if currentTrajectory and #currentTrajectory > 0 then                                                                                                                                                                                                                    
            local t = sim.getSimulationTime() - trajectoryStartTime                                                                                                                                                                                                             
                                                                                                                                                                                                                                                                                
            local p1 = nil                                                                                                                                                                                                                                                      
            local p2 = nil                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                
            if t <= currentTrajectory[1].time then                                                                                                                                                                                                                              
                p1 = currentTrajectory[1]                                                                                                                                                                                                                                       
                p2 = currentTrajectory[1]                                                                                                                                                                                                                                       
                t = currentTrajectory[1].time                                                                                                                                                                                                                                   
            elseif t >= currentTrajectory[#currentTrajectory].time then                                                                                                                                                                                                         
                p1 = currentTrajectory[#currentTrajectory]                                                                                                                                                                                                                      
                p2 = currentTrajectory[#currentTrajectory]                                                                                                                                                                                                                      
                currentTrajectory = nil                                                                                                                                                                                                                                         
            else                                                                                                                                                                                                                                                                
                for i = 1, #currentTrajectory - 1 do                                                                                                                                                                                                                            
                    if t >= currentTrajectory[i].time and t <= currentTrajectory[i+1].time then                                                                                                                                                                                 
                        p1 = currentTrajectory[i]                                                                                                                                                                                                                               
                        p2 = currentTrajectory[i+1]                                                                                                                                                                                                                             
                        break                                                                                                                                                                                                                                                   
                    end                                                                                                                                                                                                                                                         
                end                                                                                                                                                                                                                                                             
            end                                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                                                
            if p1 and p2 then                                                                                                                                                                                                                                                   
                local dt = p2.time - p1.time                                                                                                                                                                                                                                    
                local factor = 0                                                                                                                                                                                                                                                
                if dt > 0 then                                                                                                                                                                                                                                                  
                    factor = (t - p1.time) / dt                                                                                                                                                                                                                                 
                end                                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                                                
                for i=1,6 do                                                                                                                                                                                                                                                    
                    if p1.pos[i] and p2.pos[i] then                                                                                                                                                                                                                             
                        local targetPos = p1.pos[i] + (p2.pos[i] - p1.pos[i]) * factor                                                                                                                                                                                          
                        sim.setJointTargetPosition(jointHandles[i], targetPos)                                                                                                                                                                                                  
                    end                                                                                                                                                                                                                                                         
                end                                                                                                                                                                                                                                                             
            end                                                                                                                                                                                                                                                                 
        end                                                                                                                                                                                                                                                                     
    end                                                                                                                                                                                                                                                                         
  
    function sysCall_sensing()
        if csv_file then
            local t = sim.getSimulationTime()
            local pos = {}
            for i=1,6 do
                pos[i] = sim.getJointPosition(jointHandles[i])
            end
            csv_file:write(string.format("%.3f,CoppeliaSim,%.4f,%.4f,%.4f,%.4f,%.4f,%.4f\n", 
                t, pos[1], pos[2], pos[3], pos[4], pos[5], pos[6]))
        end
    end
  
    function sysCall_cleanup()
        simROS2.shutdownSubscription(subscriber)
        if csv_file then
            csv_file:close()
        end
    end
